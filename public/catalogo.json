// scripts/gerar-catalogo.js
import { put } from '@vercel/blob';
import 'dotenv/config';
import fs from 'fs/promises';

const REPLICATE_TOKEN = process.env.REPLICATE_API_TOKEN;
const BLOB_TOKEN = process.env.BLOB_READ_WRITE_TOKEN;

// Lista de desenhos (adicione quantos quiser)
const desenhos = [
  { titulo: "Cachorro fofo", categoria: "animais" },
  { titulo: "Gato dormindo", categoria: "animais" },
  { titulo: "Leão da savana", categoria: "animais" },
  { titulo: "Borboleta colorida", categoria: "insetos" },
  { titulo: "Abelha feliz", categoria: "insetos" },
  { titulo: "Mapa do Brasil", categoria: "mapas" },
  { titulo: "Mapa-múndi simples", categoria: "mapas" },
  { titulo: "Castelo da princesa", categoria: "contos" },
  { titulo: "Dragão amigável", categoria: "contos" },
  { titulo: "Unicórnio mágico", categoria: "contos" },
  { titulo: "Mona Lisa (versão infantil)", categoria: "obras de arte" },
  { titulo: "Van Gogh - Noite Estrelada", categoria: "obras de arte" },
  { titulo: "Goku de Dragon Ball", categoria: "animes" },
  { titulo: "Naruto usando Rasengan", categoria: "animes" },
  { titulo: "Batman em ação", categoria: "herois" },
  { titulo: "Superman voando", categoria: "herois" },
  { titulo: "Sonic correndo", categoria: "games" },
  { titulo: "Mario e Yoshi", categoria: "games" },
  { titulo: "Cidade de Paris com Torre Eiffel", categoria: "cidades" },
  { titulo: "Rio de Janeiro com Cristo Redentor", categoria: "cidades" },
  { titulo: "Dinossauro T-Rex", categoria: "animais pre-historicos" },
  { titulo: "Estegossauro com placas", categoria: "animais pre-historicos" },
  { titulo: "Fazenda com vaca e galinha", categoria: "fazenda" },
  { titulo: "Navio pirata no mar", categoria: "aventura" }
];

async function gerarImagemReplicate(prompt) {
  const promptCompleto = `${prompt}, kids coloring book, black and white line art, thick outline, clean lines, no shading, white background, high contrast`;

  const createResp = await fetch(
    "https://api.replicate.com/v1/models/black-forest-labs/flux-schnell/predictions",
    {
      method: "POST",
      headers: {
        "Authorization": `Token ${REPLICATE_TOKEN}`,
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        input: { prompt: promptCompleto, width: 1024, height: 1024, num_outputs: 1 }
      })
    }
  );

  if (!createResp.ok) {
    const err = await createResp.text();
    throw new Error(`Erro ao criar prediction: ${err}`);
  }

  let prediction = await createResp.json();
  const getUrl = prediction.urls.get;

  // Polling
  let tentativas = 0;
  while (prediction.status !== "succeeded" && prediction.status !== "failed") {
    if (tentativas++ > 30) throw new Error("Tempo excedido");
    await new Promise(r => setTimeout(r, 2000));
    const checkResp = await fetch(getUrl, { headers: { "Authorization": `Token ${REPLICATE_TOKEN}` } });
    if (!checkResp.ok) throw new Error("Erro no polling");
    prediction = await checkResp.json();
  }

  if (prediction.status === "succeeded") {
    const output = prediction.output;
    return Array.isArray(output) ? output[0] : output;
  } else {
    throw new Error("Falha na geração");
  }
}

async function salvarNoBlob(imageUrl, titulo) {
  const response = await fetch(imageUrl);
  const buffer = await response.arrayBuffer();
  const fileName = `catalogo/${titulo.replace(/[^a-z0-9]/gi, '-')}.png`;
  const blob = await put(fileName, buffer, { access: 'public', token: BLOB_TOKEN });
  return blob.url;
}

async function main() {
  console.log("🚀 Iniciando geração do catálogo...");
  const catalogo = [];
  for (let i = 0; i < desenhos.length; i++) {
    const { titulo, categoria } = desenhos[i];
    console.log(`[${i+1}/${desenhos.length}] Gerando: ${titulo}...`);
    try {
      const imageUrl = await gerarImagemReplicate(titulo);
      const blobUrl = await salvarNoBlob(imageUrl, titulo);
      catalogo.push({ titulo, categoria, imagemUrl: blobUrl });
      console.log(`✅ ${titulo} salvo`);
    } catch (err) {
      console.error(`❌ Erro em ${titulo}:`, err.message);
    }
    // Pausa para não sobrecarregar a API
    await new Promise(r => setTimeout(r, 1500));
  }
  // Salvar arquivo catalogo.json na pasta public
  await fs.writeFile('public/catalogo.json', JSON.stringify(catalogo, null, 2));
  console.log("🎉 Catálogo concluído! Arquivo em public/catalogo.json");
}

main();
